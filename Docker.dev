FROM gradle:8.5-jdk17

WORKDIR /app

# COPY to be enabled only in PROD ❌
# COPY . .

# Optional: install tools if needed
RUN apt-get update && apt-get install -y vim

EXPOSE 8080

CMD ["sh", "-c", "chmod +x /wait-for-it.sh && /wait-for-it.sh mysql:3306 -- ./gradlew build --continuous & ./gradlew bootRun"]